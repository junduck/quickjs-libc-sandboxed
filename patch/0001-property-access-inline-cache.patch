+/* ---- inline cache helpers ---- */
+
+static inline uint32_t ic_hash(uint32_t bc_offset, JSShape *shape)
+{
+    return ((bc_offset * 2654435761U) ^ ((uintptr_t)shape >> 4));
+}
+
+static void ic_ensure_table(JSFunctionBytecode *b, JSRuntime *rt)
+{
+    if (!b->ic_table) {
+        b->ic_table = js_mallocz_rt(rt, sizeof(JSICEntry) * IC_INITIAL_SIZE);
+        if (b->ic_table) {
+            b->ic_table_size = IC_INITIAL_SIZE;
+            b->ic_mask = IC_INITIAL_SIZE - 1;
+            b->ic_entry_count = 0;
+        }
+    }
+}
+
