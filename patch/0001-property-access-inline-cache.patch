+/* Inline cache entry for property access — direct-mapped.
+   Indexed by hash of (bc_offset, shape).  On cache hit, the full shape
+   hash lookup is skipped and the property value is read directly from
+   p->prop[slot].  Lazily populated on first miss. */
+typedef struct JSICEntry {
+    JSShape *shape;         /* expected receiver shape */
+    int16_t  slot;          /* index into p->prop[] */
+    uint16_t flags;         /* cached JS_PROP_TMASK bits */
+    uint32_t bc_offset;     /* bytecode offset of the access, for collision check */
+} JSICEntry;
 
+#define IC_INITIAL_SIZE  32
+#define IC_MAX_SIZE      4096
